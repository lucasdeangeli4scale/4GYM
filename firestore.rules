rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    match /posts/{postId} {
      allow read, write: if true;
    }

    match /config/{configId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;

      // Subcollection for physical weight history
      match /weightRecords/{recordId} {
        allow read, write: if true;
      }

      // Subcollection for weekly checklist frequency metrics
      match /frequencies/{frequencyId} {
        allow read, write: if true;
      }
    }
  }
}
